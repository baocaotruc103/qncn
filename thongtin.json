        <div class="font-bold mt-2 mb-1 text-sm italic">Quá trình công tác và hưởng lương:</div>
        <div class="overflow-x-auto">
            <table class="text-[9px] w-full">
                <thead>
                    <tr>
                        <th class="p-1">Từ tháng</th>
                        <th class="p-1">Đến tháng</th>
                        <th class="p-1">ĐV trực thuộc</th>
                        <th class="p-1">ĐV chi tiết</th>
                        <th class="p-1">Loại thay đổi</th>
                        <th class="p-1">Diện QL</th>
                        <th class="p-1">Diện bố trí</th>
                        <th class="p-1">Cấp bậc</th>
                        <th class="p-1">Chức vụ, CNQS</th>
