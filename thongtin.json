        </table>

        <div class="font-bold mt-2 mb-1 text-sm italic underline">3. Thông tin kỷ luật:</div>
        <table>
            <thead>
                <tr>
                    <th class="w-24">Ngày tháng năm</th>
                    <th class="w-32">Đánh giá xếp loại</th>
                    <th>Lý do</th>
                    <th class="w-28">Loại</th>
                    <th class="w-32">Cấp</th>
