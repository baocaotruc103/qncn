                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="19" class="text-center italic text-gray-500 py-6">Chưa có dữ liệu quá trình công tác</td>
                    </tr>
                </tbody>
            </table>
        </div>
        
        <div class="flex justify-end mt-12">
            <div class="text-center">
                <p class="italic mb-1">........, ngày ..... tháng ..... năm .......</p>
                <p class="font-bold">Người khai</p>
                <p class="italic text-xs mb-12">(Ký và ghi rõ họ tên)</p>
                <p class="font-bold">TRẦN THỊ THU HUYỀN</p>
            </div>
        </div>
    </div>

</body>
</html>